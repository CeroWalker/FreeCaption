# FreeCaption — backend ortam degiskenleri
# install_vds.sh bu dosyayi .env olarak kopyalar ve FC_API_KEY'i random olarak doldurur.

# Mod: cpu (VDS) | gpu (lokal)
FC_MODE=cpu

# Model: tiny, base, small, medium, large-v3
# CPU icin medium = en iyi denge (hiz/dogruluk)
FC_MODEL=medium

# Alignment (WhisperX) — CPU'da cok yavas, 0 ile kapali
FC_ALIGN=0

# Bind adresi: 0.0.0.0 = nginx'in arkasinda public
FC_HOST=0.0.0.0
FC_PORT=7860

# API authentication — bos string ise auth devre disi (sadece lokal!)
# Production'da MUTLAKA doldur (random 32+ karakter)
FC_API_KEY=

# Upload limit (MB)
FC_MAX_UPLOAD_MB=500

# Batch (RAM'e gore: 16 default, 8 daha az RAM kullanir)
FC_BATCH=8
